generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  OFICINA
  LECTURA
}

enum DocumentStatus {
  PENDIENTE
  PROCESADO
  REVISADO
  ERROR
}

enum PayrollStatus {
  BORRADOR
  VALIDADA
  CERRADA
  PAGADA
}

enum ExpenseTarget {
  ARMADOR
  TRIPULACION
  AMBOS
  BARCO
}

enum AllocationMethod {
  PORCENTAJE_FIJO
  PARTES_IGUALES
  CATEGORIA
  PERSONALIZADO
}

enum PeriodStatus {
  ABIERTO
  CERRADO
  BLOQUEADO
}

// ─── USUARIOS Y ROLES ─────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  role         UserRole  @default(LECTURA)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  documents    Document[]
  auditLogs    AuditLog[]
  payrollRuns  PayrollRun[]

  @@map("users")
}

// ─── MAESTROS ─────────────────────────────────────────────────────────────────

model Boat {
  id           String    @id @default(cuid())
  name         String
  registration String    @unique
  flag         String?
  boatType     String?   @map("boat_type")
  lengthM      Decimal?  @map("length_m") @db.Decimal(6, 2)
  tonGt        Decimal?  @map("ton_gt") @db.Decimal(8, 2)
  active       Boolean   @default(true)
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  invoices     Invoice[]
  crewMembers  CrewMember[]
  payrollRuns  PayrollRun[]
  expenses     Expense[]

  @@map("boats")
}

model Port {
  id        String    @id @default(cuid())
  name      String
  code      String?   @unique
  province  String?
  country   String    @default("España")
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  invoices  Invoice[]

  @@map("ports")
}

model Supplier {
  id        String    @id @default(cuid())
  name      String
  taxId     String?   @unique @map("tax_id")
  portId    String?   @map("port_id")
  address   String?
  phone     String?
  email     String?
  active    Boolean   @default(true)
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  invoices  Invoice[]

  @@map("suppliers")
}

model Species {
  id           String    @id @default(cuid())
  name         String
  scientificName String? @map("scientific_name")
  code         String?   @unique
  category     String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  invoiceLines InvoiceLine[]

  @@map("species")
}

model CrewCategory {
  id                   String    @id @default(cuid())
  name                 String
  code                 String    @unique
  allocationParts      Decimal   @default(1) @map("allocation_parts") @db.Decimal(5, 2)
  socialSecurityGroup  String?   @map("social_security_group")
  notes                String?
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  crewMembers          CrewMember[]

  @@map("crew_categories")
}

model CrewMember {
  id           String       @id @default(cuid())
  name         String
  lastName     String       @map("last_name")
  taxId        String?      @unique @map("tax_id")
  socialSecId  String?      @map("social_sec_id")
  categoryId   String       @map("category_id")
  boatId       String?      @map("boat_id")
  irpfPercent  Decimal      @default(0) @map("irpf_percent") @db.Decimal(5, 2)
  bankAccount  String?      @map("bank_account")
  phone        String?
  email        String?
  active       Boolean      @default(true)
  joinDate     DateTime?    @map("join_date")
  leaveDate    DateTime?    @map("leave_date")
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  category     CrewCategory @relation(fields: [categoryId], references: [id])
  boat         Boat?        @relation(fields: [boatId], references: [id])
  payrollItems PayrollItem[]
  expenses     Expense[]

  @@map("crew_members")
}

model ExpenseType {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique
  target    ExpenseTarget @default(AMBOS)
  active    Boolean   @default(true)
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  expenses  Expense[]

  @@map("expense_types")
}

// ─── PERÍODOS ─────────────────────────────────────────────────────────────────

model PayrollPeriod {
  id          String        @id @default(cuid())
  name        String
  startDate   DateTime      @map("start_date")
  endDate     DateTime      @map("end_date")
  status      PeriodStatus  @default(ABIERTO)
  boatId      String?       @map("boat_id")
  lockedAt    DateTime?     @map("locked_at")
  lockedBy    String?       @map("locked_by")
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  payrollRuns PayrollRun[]
  expenses    Expense[]

  @@map("payroll_periods")
}

// ─── DOCUMENTOS E IMPORTACIÓN ─────────────────────────────────────────────────

model Document {
  id            String         @id @default(cuid())
  filename      String
  originalName  String         @map("original_name")
  mimeType      String         @map("mime_type")
  sizBytes      Int            @map("siz_bytes")
  storagePath   String         @map("storage_path")
  status        DocumentStatus @default(PENDIENTE)
  extractedData Json?          @map("extracted_data")
  errorMessage  String?        @map("error_message")
  uploadedById  String         @map("uploaded_by_id")
  invoiceId     String?        @unique @map("invoice_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  uploadedBy    User           @relation(fields: [uploadedById], references: [id])
  invoice       Invoice?       @relation(fields: [invoiceId], references: [id])

  @@map("documents")
}

// ─── FACTURAS / CAPTURAS ──────────────────────────────────────────────────────

model Invoice {
  id               String    @id @default(cuid())
  invoiceNumber    String?   @map("invoice_number")
  invoiceDate      DateTime  @map("invoice_date")
  portId           String?   @map("port_id")
  supplierId       String?   @map("supplier_id")
  boatId           String?   @map("boat_id")
  subtotal         Decimal   @default(0) @db.Decimal(12, 2)
  taxAmount        Decimal   @default(0) @map("tax_amount") @db.Decimal(12, 2)
  feesAmount       Decimal   @default(0) @map("fees_amount") @db.Decimal(12, 2)
  discountAmount   Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount      Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  observations     String?
  reviewed         Boolean   @default(false)
  reviewedAt       DateTime? @map("reviewed_at")
  reviewedBy       String?   @map("reviewed_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  port             Port?     @relation(fields: [portId], references: [id])
  supplier         Supplier? @relation(fields: [supplierId], references: [id])
  boat             Boat?     @relation(fields: [boatId], references: [id])
  lines            InvoiceLine[]
  document         Document?

  @@map("invoices")
}

model InvoiceLine {
  id           String    @id @default(cuid())
  invoiceId    String    @map("invoice_id")
  speciesId    String?   @map("species_id")
  speciesName  String?   @map("species_name")
  kilos        Decimal   @db.Decimal(10, 3)
  pricePerKilo Decimal   @map("price_per_kilo") @db.Decimal(10, 4)
  lineAmount   Decimal   @map("line_amount") @db.Decimal(12, 2)
  boxCount     Int?      @map("box_count")
  quality      String?
  observations String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  invoice      Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  species      Species?  @relation(fields: [speciesId], references: [id])

  @@map("invoice_lines")
}

// ─── GASTOS ───────────────────────────────────────────────────────────────────

model Expense {
  id            String        @id @default(cuid())
  expenseTypeId String        @map("expense_type_id")
  periodId      String?       @map("period_id")
  boatId        String?       @map("boat_id")
  crewMemberId  String?       @map("crew_member_id")
  amount        Decimal       @db.Decimal(12, 2)
  target        ExpenseTarget @default(AMBOS)
  description   String?
  date          DateTime
  receiptRef    String?       @map("receipt_ref")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  expenseType   ExpenseType   @relation(fields: [expenseTypeId], references: [id])
  period        PayrollPeriod? @relation(fields: [periodId], references: [id])
  boat          Boat?         @relation(fields: [boatId], references: [id])
  crewMember    CrewMember?   @relation(fields: [crewMemberId], references: [id])

  @@map("expenses")
}

// ─── PARÁMETROS DE CÁLCULO ────────────────────────────────────────────────────

model AllocationRule {
  id              String           @id @default(cuid())
  name            String
  boatId          String?          @map("boat_id")
  ownerPercent    Decimal          @map("owner_percent") @db.Decimal(5, 2)
  crewPercent     Decimal          @map("crew_percent") @db.Decimal(5, 2)
  method          AllocationMethod @default(PORCENTAJE_FIJO)
  deductExpensesFrom String        @default("MONTE_MAYOR") @map("deduct_expenses_from")
  active          Boolean          @default(true)
  validFrom       DateTime?        @map("valid_from")
  validTo         DateTime?        @map("valid_to")
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("allocation_rules")
}

model TaxParameter {
  id             String    @id @default(cuid())
  name           String
  code           String    @unique
  value          Decimal   @db.Decimal(8, 4)
  description    String?
  validFrom      DateTime  @map("valid_from")
  validTo        DateTime? @map("valid_to")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("tax_parameters")
}

model SocialSecurityParameter {
  id                  String    @id @default(cuid())
  name                String
  code                String    @unique
  employeePercent     Decimal   @map("employee_percent") @db.Decimal(5, 4)
  employerPercent     Decimal   @map("employer_percent") @db.Decimal(5, 4)
  baseType            String    @default("TOTAL_CAPTURAS") @map("base_type")
  description         String?
  validFrom           DateTime  @map("valid_from")
  validTo             DateTime? @map("valid_to")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("social_security_parameters")
}

// ─── NÓMINAS / LIQUIDACIONES ──────────────────────────────────────────────────

model PayrollRun {
  id              String        @id @default(cuid())
  periodId        String        @map("period_id")
  boatId          String        @map("boat_id")
  runByUserId     String        @map("run_by_user_id")
  status          PayrollStatus @default(BORRADOR)
  totalCapturas   Decimal       @map("total_capturas") @db.Decimal(14, 2)
  monteMayor      Decimal       @map("monte_mayor") @db.Decimal(14, 2)
  totalGastos     Decimal       @map("total_gastos") @db.Decimal(14, 2)
  baseRepartible  Decimal       @map("base_repartible") @db.Decimal(14, 2)
  ownerShare      Decimal       @map("owner_share") @db.Decimal(14, 2)
  crewShare       Decimal       @map("crew_share") @db.Decimal(14, 2)
  totalBruto      Decimal       @map("total_bruto") @db.Decimal(14, 2)
  totalSS         Decimal       @map("total_ss") @db.Decimal(14, 2)
  totalIRPF       Decimal       @map("total_irpf") @db.Decimal(14, 2)
  totalNeto       Decimal       @map("total_neto") @db.Decimal(14, 2)
  rulesSnapshot   Json          @map("rules_snapshot")
  inputSnapshot   Json          @map("input_snapshot")
  calculatedAt    DateTime      @default(now()) @map("calculated_at")
  validatedAt     DateTime?     @map("validated_at")
  closedAt        DateTime?     @map("closed_at")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  period          PayrollPeriod @relation(fields: [periodId], references: [id])
  boat            Boat          @relation(fields: [boatId], references: [id])
  runByUser       User          @relation(fields: [runByUserId], references: [id])
  items           PayrollItem[]

  @@map("payroll_runs")
}

model PayrollItem {
  id                String      @id @default(cuid())
  payrollRunId      String      @map("payroll_run_id")
  crewMemberId      String      @map("crew_member_id")
  baseParts         Decimal     @map("base_parts") @db.Decimal(5, 2)
  brutoPescador     Decimal     @map("bruto_pescador") @db.Decimal(12, 2)
  ssEmployee        Decimal     @map("ss_employee") @db.Decimal(12, 2)
  ssEmployer        Decimal     @map("ss_employer") @db.Decimal(12, 2)
  irpfPercent       Decimal     @map("irpf_percent") @db.Decimal(5, 2)
  irpfAmount        Decimal     @map("irpf_amount") @db.Decimal(12, 2)
  otherDeductions   Decimal     @default(0) @map("other_deductions") @db.Decimal(12, 2)
  netoPescador      Decimal     @map("neto_pescador") @db.Decimal(12, 2)
  status            PayrollStatus @default(BORRADOR)
  manualAdjustment  Decimal     @default(0) @map("manual_adjustment") @db.Decimal(12, 2)
  adjustmentNote    String?     @map("adjustment_note")
  calculationDetail Json        @map("calculation_detail")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  payrollRun        PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  crewMember        CrewMember  @relation(fields: [crewMemberId], references: [id])

  @@map("payroll_items")
}

// ─── AUDITORÍA ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String
  entity     String
  entityId   String   @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
