{
  "name": "capturas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "prisma db push --accept-data-loss && next start -p ${PORT:-3000}",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset --force",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "watch": "tsx scripts/watch.ts",
    "backup": "tsx scripts/backup.ts",
    "reparse:format": "tsx scripts/reparse-by-format.ts",
    "seed:port-taxes": "tsx scripts/seed-port-tax-rates.ts",
    "seed:sailors": "tsx scripts/seed-sailors.ts",
    "seed:gijon": "tsx scripts/seed-gijon.ts",
    "seed:sanvicente": "tsx scripts/seed-sanvicente.ts",
    "seed:aviles": "tsx scripts/seed-aviles.ts",
    "check:santona": "tsx scripts/check-santona.ts",
    "check:docs": "tsx scripts/check-docs.ts",
    "classify": "tsx scripts/classify-pdf.ts",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "jose": "^5.9.6",
    "next": "^14.2.35",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^2.13.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.13.5",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
