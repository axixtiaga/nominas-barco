DATABASE_URL="postgresql://postgres:postgres@localhost:5432/capturas?schema=public"
AUTH_SECRET="change-me-in-production-please-at-least-32-chars"
NODE_ENV="development"

# ── Folder watcher ────────────────────────────────────────────────
# Carpeta en la que Dropbox deja los PDFs de capturas. El watcher
# vigila esta ruta de forma recursiva y auto-importa los nuevos PDFs.
WATCH_FOLDER="C:\\Users\\User\\Dropbox\\Itsas Lagunak\\Cuentas 2026\\Capturas Txanteles"
WATCH_RECURSIVE="true"
# Si es true, el nombre de la subcarpeta inmediata se usa como pista
# (portHint) para el clasificador de formatos. Ej: .../Hondarribia/xxx.pdf → portHint=Hondarribia
WATCH_PORT_HINT_FROM_SUBFOLDER="true"
# Milisegundos que un fichero debe estar "estable" antes de procesarlo
# (Dropbox a veces escribe en dos pasadas). 1500 es seguro.
WATCH_STABILITY_MS="1500"
