# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/nominas_barco"

# JWT Secret (genera uno con: openssl rand -base64 32)
JWT_SECRET="tu_jwt_secret_muy_seguro_aqui"

# Entorno
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3000"

# Almacenamiento de documentos (ruta local en desarrollo)
UPLOAD_DIR="./uploads"

# Opcional: para OCR en producción
# GOOGLE_VISION_API_KEY=""
# AWS_TEXTRACT_REGION=""
# AWS_TEXTRACT_ACCESS_KEY=""
# AWS_TEXTRACT_SECRET_KEY=""
